# Sentinel-Dev configuration (set these as GitHub Actions secrets / variables).

# GitHub auth. OPTIONAL locally: if unset, Sentinel uses the GitHub CLI
# (`gh auth token`) — just run `npm run login` once. Provided automatically
# inside GitHub Actions.
GITHUB_TOKEN=
# Only needed for the one-shot `fix`/`finalize` Action; the watcher auto-discovers.
GITHUB_REPOSITORY=owner/repo

# LLM provider: "anthropic" (default) or "openai".
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Poke inbound webhook (V2 endpoint by default; use the legacy
# /api/v1/inbound-sms/webhook URL if you have a pk_ key).
POKE_API_KEY=
POKE_WEBHOOK_URL=https://poke.com/api/v1/inbound/api-message

# Stream progress updates to Poke during the fix run (true/false).
POKE_PROGRESS=true

# Port for the MCP server that Poke connects to (mcp / serve commands).
MCP_PORT=3000

# --- Always-on watcher (`serve` command) ---------------------------------
# Who writes the fix:
#   "poke"     -> ask Poke to spin up a Cursor VM (uses Poke's Cursor integration; default)
#   "cursor"   -> mention @cursor on the issue (needs the Cursor GitHub App)
#   "sentinel" -> add the Sentinel-Fix label to run the in-repo LLM workflow
FIX_ENGINE=poke
# The mention that triggers Cursor's GitHub App (only used when FIX_ENGINE=cursor).
CURSOR_MENTION=@cursor
# Repos to watch, comma-separated "owner/repo,owner/repo2".
# Leave BLANK to auto-discover repos you can push to (via your GitHub auth).
WATCH_REPOS=
# Cap on auto-discovered repos (most-recently-pushed first).
WATCH_MAX_REPOS=20
# Only act on issues with this label (blank = every new open issue).
WATCH_LABEL=
# How often to poll, in milliseconds.
WATCH_INTERVAL_MS=60000
# Act on issues that already exist at startup (true) or only new ones (false).
WATCH_BACKFILL=false
# Where the watcher records which issues it has already handled.
STATE_FILE=.sentinel-state.json

# Where failure / decline logs are emailed.
NOTIFY_EMAIL=princekmr14214@gmail.com

# Optional: override the auto-detected test command (npm test / pytest).
TEST_COMMAND=

# Used only by the finalize step (set by the approval workflow).
DECISION=
BRANCH=
ISSUE_NUMBER=
